{
  "description": "Order Management System App",
  "author": "Kostas Veloutsos",
  "name": "OMS",
  "homepage": "./",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.oms.desktop",
    "productName": "OMS",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**",
      "electron/**"
    ],

    "asar": false,

    "win": {
      "target": "nsis"
    }
  },
  "files": [
    "dist/**",
    "electron/**"
  ],
  "asar": false,
  "win": {
    "target": "nsis"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "dist": "electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@material-tailwind/react": "^2.1.10",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.10",
    "@mui/x-data-grid": "^8.25.0",
    "@mui/x-data-grid-pro": "^9.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "bootstrap": "^5.3.8",
    "electron-context-menu": "^4.1.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-collapse": "^5.1.1",
    "react-dom": "^19.2.0",
    "react-router": "^7.12.0",
    "react-select": "^5.10.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-collapse": "^5.0.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.5"
  }
}
